# ===== 全局默认 =====
[ai]
base_url = "https://api.openai.com/v1"
api_key  = "sk-your-api-key"
model    = "gpt-4o-mini"

# ===== 分步骤覆盖（可选） =====
# 只覆盖需要不同配置的字段即可，未填写的字段会回退到 [ai] 的全局默认或对应环境变量

# Step 2：生成 normalize.py，建议使用能力较强的模型以获得更好的结构规范化效果
[ai.step2]
model = "gpt-4o"

# Step 4：根据访谈结果生成阅读策略 strategy.md，对模型能力要求较低
[ai.step4]
model = "gpt-4o-mini"

# Step 5：生成 transform.py，建议使用能力较强的模型
[ai.step5]
model = "gpt-4o"
