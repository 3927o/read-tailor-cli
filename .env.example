# ===== 全局默认 =====
# OpenAI 兼容接口；程序会自动补 /v1/chat/completions，可以直接写到根路径或 /v1
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o-mini

# ===== 分步骤覆盖（可选，留空则使用全局默认） =====

# Step 2：生成 normalize.py，用于把 raw HTML 规范化为标准书籍结构
# AI_BASE_URL_STEP2=
# AI_API_KEY_STEP2=
# AI_MODEL_STEP2=gpt-4o

# Step 4：根据访谈结果生成阅读策略 strategy.md
# AI_BASE_URL_STEP4=
# AI_API_KEY_STEP4=
# AI_MODEL_STEP4=gpt-4o-mini

# Step 5：生成 transform.py，用于把规范化 HTML 转成最终阅读版
# AI_BASE_URL_STEP5=
# AI_API_KEY_STEP5=
# AI_MODEL_STEP5=gpt-4o

